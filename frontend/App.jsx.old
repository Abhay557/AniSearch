import React, { useState } from 'react';
import { Search, Loader2, Star, PlayCircle, Info, Sparkles } from 'lucide-react';

export default function App() {
  const [query, setQuery] = useState('');
  const [results, setResults] = useState([]);
  const [isSearching, setIsSearching] = useState(false);
  const [error, setError] = useState('');

  // Replace this with your actual Hugging Face Space URL
  const BACKEND_URL = "https://abhay557-animesearch.hf.space";

  const handleSearch = async (e) => {
    e.preventDefault();
    if (!query.trim()) return;

    setIsSearching(true);
    setError('');
    setResults([]);
    
    try {
      const response = await fetch(`${BACKEND_URL}/search?q=${encodeURIComponent(query)}`);
      
      if (!response.ok) {
        throw new Error('Backend not available');
      }
      
      const data = await response.json();
      setResults(data.results);
      
    } catch (err) {
      console.error("Search failed:", err);
      setError('Unable to connect to the search engine. Please make sure the backend is live.');
    } finally {
      setIsSearching(false);
    }
  };

  return (
    <div className="min-h-screen bg-[#09090b] text-zinc-200 font-sans selection:bg-indigo-500/30 overflow-hidden relative">
      {/* Background ambient glow */}
      <div className="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-indigo-600/10 blur-[120px] pointer-events-none" />
      <div className="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-purple-600/10 blur-[120px] pointer-events-none" />

      <main className="relative z-10 max-w-[1600px] mx-auto px-6 py-12 md:py-20">
        {/* Hero Search Section */}
        <div className="max-w-4xl mx-auto flex flex-col items-center text-center mb-24">
          <h2 className="text-5xl md:text-7xl font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-b from-white to-zinc-500 mb-6">
            Find your next obsession.
          </h2>
          <p className="text-lg md:text-xl text-zinc-400 mb-10 max-w-2xl font-light">
            Don't search by title. Search by the plot, the mood, or the exact crazy scenario you're looking for.
          </p>
          
          <form onSubmit={handleSearch} className="w-full relative group max-w-3xl">
            <div className="absolute inset-0 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full blur-xl opacity-20 group-hover:opacity-40 transition-opacity duration-500" />
            <div className="relative flex items-center bg-[#131316] border border-zinc-800 rounded-full p-2 shadow-2xl backdrop-blur-xl transition-all focus-within:border-indigo-500/50">
              <Search className="w-6 h-6 text-zinc-500 ml-4 absolute pointer-events-none" />
              <input
                type="text"
                value={query}
                onChange={(e) => setQuery(e.target.value)}
                placeholder="e.g., A cyberpunk detective fighting rogue AI..."
                className="w-full bg-transparent border-none py-4 pl-14 pr-32 text-lg text-white placeholder-zinc-600 focus:outline-none focus:ring-0"
              />
              <button 
                type="submit"
                disabled={isSearching || !query.trim()}
                className="absolute right-3 px-8 py-3 bg-white hover:bg-zinc-200 text-black rounded-full font-bold transition-all disabled:opacity-50 disabled:hover:bg-white flex items-center gap-2 h-[calc(100%-24px)]"
              >
                {isSearching ? <Loader2 className="w-5 h-5 animate-spin" /> : 'Explore'}
              </button>
            </div>
          </form>
        </div>

        {/* Error Message */}
        {error && (
          <div className="max-w-3xl mx-auto mb-12 p-5 bg-red-500/10 border border-red-500/20 rounded-2xl flex items-center justify-center gap-3 text-red-400 backdrop-blur-sm">
            <Info className="w-5 h-5" />
            <p className="font-medium">{error}</p>
          </div>
        )}

        {/* Cinematic Results Grid */}
        {results.length > 0 && (
          <div className="animate-in fade-in slide-in-from-bottom-10 duration-1000">
            <div className="flex items-center justify-between mb-8">
              <h3 className="text-2xl font-bold text-white tracking-tight">
                Top Matches
              </h3>
              <span className="text-zinc-500 text-sm font-medium">{results.length} results found</span>
            </div>
            
            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8">
              {results.map((anime, index) => (
                <div 
                  key={index} 
                  className="group relative flex flex-col justify-end overflow-hidden rounded-3xl bg-[#131316] border border-zinc-800/80 aspect-[2/3] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_-15px_rgba(99,102,241,0.3)] hover:border-indigo-500/50 cursor-pointer"
                >
                  {/* Real Image Layer */}
                  {anime.image ? (
                    <img 
                      src={anime.image} 
                      alt={anime.title} 
                      className="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-60 group-hover:opacity-40"
                      onError={(e) => { e.target.style.display = 'none'; }}
                    />
                  ) : (
                    <div className="absolute inset-0 bg-gradient-to-br from-zinc-800/20 to-zinc-950" />
                  )}

                  {/* Gradient Overlay for Text Legibility */}
                  <div className="absolute inset-0 bg-gradient-to-t from-[#09090b] via-[#09090b]/60 to-transparent opacity-90" />
                  
                  {/* Score Badge - Floating top right */}
                  <div className="absolute top-4 right-4 z-20">
                    <div className="bg-black/60 backdrop-blur-md border border-white/10 text-white text-xs px-3 py-1.5 rounded-full font-bold shadow-xl flex items-center gap-1.5">
                      <Sparkles className="w-3 h-3 text-indigo-400" />
                      {(anime.score * 100).toFixed(0)}%
                    </div>
                  </div>

                  {/* Content Overlay */}
                  <div className="relative z-10 p-6 flex flex-col h-full justify-end">
                    <h2 className="text-2xl md:text-3xl font-bold text-white mb-3 line-clamp-2 leading-tight group-hover:text-indigo-400 transition-colors duration-300">
                      {anime.title}
                    </h2>
                    
                    <p className="text-zinc-400 text-sm line-clamp-3 leading-relaxed mb-6 opacity-80 group-hover:opacity-100 transition-opacity">
                      {anime.synopsis}
                    </p>

                    <div className="flex items-center gap-3 mb-4 text-xs font-semibold text-zinc-500">
                      <span className="flex items-center gap-1 text-zinc-300">
                        <Star className="w-3.5 h-3.5 text-indigo-400" fill="currentColor" />
                        {anime.mal_score || 'N/A'}
                      </span>
                      <span className="w-1 h-1 rounded-full bg-zinc-700" />
                      <span>{anime.episodes === '?' || anime.episodes === null ? 'Ongoing' : `${anime.episodes} EPS`}</span>
                    </div>

                    <div className="flex flex-wrap gap-2">
                      {anime.genres && anime.genres.split(',').slice(0, 3).map((genre, i) => (
                        <span key={i} className="text-[10px] uppercase tracking-wider font-bold text-zinc-300 bg-white/5 border border-white/10 px-2.5 py-1 rounded-lg backdrop-blur-sm">
                          {genre.trim()}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </main>
    </div>
  );
}